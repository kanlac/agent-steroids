{
  "description": "Payload size guard + Telegram time awareness injection",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__plugin_telegram_telegram__react",
        "hooks": [
          {
            "type": "command",
            "command": "date '+%Y-%m-%d %H:%M %Z'",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/guard-payload-size.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
